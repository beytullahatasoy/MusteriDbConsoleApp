// MusteriDbBağlantısını appsettings.json dosyasında tanımladık.
{
  "ConnectionStrings": {
    "MusteriDbBaglantisi": "Server=localhost;Database=MusteriDB;Trusted_Connection=True;TrustServerCertificate=True;"
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}